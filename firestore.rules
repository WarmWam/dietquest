rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user data (logs, plans, settings, profile)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared library catalog — every authenticated user can read & write
    // (DietQuest is a small trusted-circle app: you + wife/friends only)
    match /library_foods/{foodId} {
      allow read, write: if request.auth != null;
    }

    // Shared analysis usage counter so the small trusted group sees the
    // same Gemini daily quota usage.
    match /analysis_usage/{usageId} {
      allow read, write: if request.auth != null;
    }
  }
}
